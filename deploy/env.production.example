# =============================================================================
# NorFood — Produção VPS 8 GB
# Copie para /opt/norfood/.env e preencha os valores.
# =============================================================================

NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Build: node-server | Deploy Vercel: vercel (padrão)
NITRO_PRESET=node-server

# --- Capacidade (VPS 8 GB, Supabase externo) ---
NORFOOD_CAPACITY_PROFILE=vps-8gb
NORFOOD_MAX_TENANTS=35
NORFOOD_PM2_INSTANCES=3
# Se rodar gateway WhatsApp na mesma VPS:
# NORFOOD_EVOLUTION_ON_VPS=true
# NORFOOD_MAX_TENANTS_WITH_EVOLUTION=15

# URL pública (HTTPS) — usada em webhooks e links
PUBLIC_APP_URL=https://norfood.com.br

VITE_DEMO_MODE=false

SUPABASE_PROJECT_ID=seu-project-id
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_PUBLISHABLE_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-anon-key

PLATFORM_ADMIN_EMAILS=seu@email.com
VITE_PLATFORM_ADMIN_EMAILS=seu@email.com

# Segurança (gere strings aleatórias longas)
ENCRYPTION_KEY=
CRON_SECRET=

# Mercado Pago
MP_ACCESS_TOKEN=
VITE_MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_WEBHOOK_URL=https://app.seudominio.com.br/api/mercado-pago/webhook
MP_STATEMENT_DESCRIPTOR=NORFOOD
MP_ENVIRONMENT=production

# WhatsApp Meta (recomendado em produção)
WABA_WEBHOOK_URL=https://norfood.com.br/api/waba/webhook
WABA_VERIFY_TOKEN=norfood-waba-2026
META_APP_ID=
META_APP_SECRET=
# E-mail de contato do app no Facebook Developer (Meta envia alertas aqui)
META_APP_CONTACT_EMAIL=meta@norfood.com.br
VITE_META_APP_CONTACT_EMAIL=meta@norfood.com.br

# WhatsApp Web — gateway Baileys (substitui Evolution API)
WHATSAPP_GATEWAY_URL=http://whatsapp-gateway:8090
# Obrigatorio em producao — use a mesma chave no container norfood e whatsapp-gateway
WHATSAPP_GATEWAY_KEY=defina-uma-chave-segura-aqui
WHATSAPP_AUTH_DIR=/data/auth
WHATSAPP_INSTANCE_NAME=norfood
WHATSAPP_WEBHOOK_URL=https://app.seudominio.com.br/api/whatsapp/webhook

# Evolution (legado — remova após cutover)
# EVOLUTION_API_URL=http://evolution:8080
# EVOLUTION_API_KEY=
# EVOLUTION_WEBHOOK_SECRET=

# Caddy (docker-compose)
DOMAIN=app.seudominio.com.br
ACME_EMAIL=seu@email.com

# Expo Go — QR no painel entregadores (Metro na VPS porta 8081)
EXPO_GO_URL=exp://SEU_IP_VPS:8081
EXPO_METRO_HOST=SEU_IP_VPS
EXPO_METRO_PORT=8081

# E-mail transacional (aprovação de cadastro) — https://resend.com (plano free)
# RESEND_API_KEY=re_...
# PLATFORM_EMAIL_FROM=Norfood <cadastro@norfood.com.br>
# PLATFORM_EMAIL_CONTACT_FROM=Norfood <contato@norfood.com.br>
# Opcional: subdomínio dedicado no Resend (painel → Domains → contato.norfood.com.br)
# PLATFORM_EMAIL_CONTACT_FROM=Norfood <contato@contato.norfood.com.br>
# Remetente integrações Meta / Facebook Developer (opcional)
# PLATFORM_EMAIL_META_FROM=Norfood <meta@norfood.com.br>
